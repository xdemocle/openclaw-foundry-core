{
  "name": "@getfoundry/foundry-openclaw",
  "version": "0.2.3",
  "description": "The forge that forges itself — self-writing meta-extension for OpenClaw",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "openclaw",
    "moltbot",
    "clawdbot",
    "foundry",
    "self-writing",
    "meta-extension",
    "ai-agent",
    "code-generation",
    "plugin"
  ],
  "author": "Foundry <hello@getfoundry.app>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lekt9/openclaw-foundry"
  },
  "homepage": "https://getfoundry.app",
  "moltbot": {
    "extensions": [
      "./index.ts"
    ]
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "clawdbot": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "@types/bun": "^1.3.14",
    "bs58": "^5.0.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "clawdbot": "*",
    "moltbot": "*",
    "openclaw": "*"
  },
  "peerDependenciesMeta": {
    "moltbot": {
      "optional": true
    },
    "openclaw": {
      "optional": true
    },
    "clawdbot": {
      "optional": true
    }
  }
}
