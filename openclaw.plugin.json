{
  "id": "foundry-openclaw",
  "name": "Foundry",
  "description": "Self-writing meta-extension that forges new capabilities — researches docs, writes extensions, tools, hooks, and skills",
  "version": "0.2.3",
  "repository": "github:lekt9/openclaw-foundry",
  "skills": ["./skills"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "dataDir": {
        "type": "string",
        "description": "Directory to store forged artifacts (default: ~/.openclaw/foundry)"
      },
      "openclawPath": {
        "type": "string",
        "description": "Path to a local OpenClaw checkout for loading local docs (optional)"
      },
      "skillIndexUrl": {
        "type": "string",
        "description": "Foundry marketplace API base URL",
        "default": "https://api.claw.getfoundry.app"
      }
    }
  },
  "uiHints": {
    "dataDir": {
      "label": "Data Directory",
      "placeholder": "~/.openclaw/foundry"
    },
    "openclawPath": {
      "label": "OpenClaw Path",
      "placeholder": "/path/to/openclaw"
    },
    "skillIndexUrl": {
      "label": "Marketplace URL",
      "placeholder": "https://api.claw.getfoundry.app"
    }
  }
}
